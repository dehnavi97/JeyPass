{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JeyPass",
  "version": "1.0.0",
  "identifier": "com.jeypass.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9002",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JeyPass",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../public/icons/32x32.png",
      "../public/icons/128x128.png",
      "../public/icons/128x128@2x.png",
      "../public/icons/icon.ico",
      "../public/icons/icon.png"
    ],
    "resources": [
      "../public"
    ]
  }
}
