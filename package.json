{
  "name": "jeypass-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "JeyPass is a modern, secure, and offline-capable password manager.",
  "author": {
    "name": "Javad Dehnavi",
    "email": "dehnavi97@gmail.com",
    "url": "https://github.com/dehnavi97"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "dev:desktop": "concurrently -k \"npm:dev\" \"tauri dev\"",
    "build": "next build",
    "build:desktop": "npm run build && tauri build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "npm run build",
    "tauri": "tauri",
    "assets:generate": "capacitor-assets generate --android",
    "assets:generate:icons": "capacitor-assets generate --android --icon-background-color '#ffffff' --icon-background-color-dark '#ffffff'",
    "sync:android": "npm run assets:generate && next build && npx cap sync android",
    "open:android": "npx cap open android",
    "sync:ios": "npm run assets:generate && next build && npx cap sync ios",
    "open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.1",
    "@capacitor/camera": "^6.0.1",
    "@capacitor/core": "^6.1.1",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/ios": "^6.1.1",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tauri-apps/api": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^7.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.475.0",
    "next": "15.5.9",
    "otpauth": "^9.2.2",
    "patch-package": "^8.0.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.0.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jeypass.app",
    "productName": "JeyPass",
    "files": [
      "dist/**/*",
      "next.config.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
